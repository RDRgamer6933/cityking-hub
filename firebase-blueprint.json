{
  "entities": {
    "Server": {
      "title": "Minecraft Server",
      "description": "A Minecraft server listed in the hub.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Server name" },
        "javaIp": { "type": "string", "description": "Java Edition IP address" },
        "bedrockIp": { "type": "string", "description": "Bedrock Edition IP address" },
        "bedrockPort": { "type": "integer", "description": "Bedrock Edition port" },
        "motd": { "type": "string", "description": "Server MOTD (short message)" },
        "motdColor": { "type": "string", "description": "Hex color for the MOTD" },
        "discordUrl": { "type": "string", "description": "Discord invite link" },
        "mode": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of game modes (Survival, PvP, etc.)" 
        },
        "version": { "type": "string", "description": "Minecraft version" },
        "description": { "type": "string", "description": "Server description" },
        "votes": { "type": "integer", "description": "Total vote count" },
        "isOfficial": { "type": "boolean", "description": "Whether it's the CityKing official server" },
        "createdBy": { "type": "string", "description": "UID of the user who added it" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "javaIp", "mode", "version", "votes"]
    },
    "Vote": {
      "title": "Server Vote",
      "description": "A vote cast by a user. The document ID is the user's UID to enforce a 24h limit.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the voter" },
        "serverId": { "type": "string", "description": "ID of the server voted for" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the vote was cast" }
      },
      "required": ["userId", "serverId", "timestamp"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the global chat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the sender" },
        "userName": { "type": "string", "description": "Display name of the sender" },
        "text": { "type": "string", "description": "Message content" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["userId", "userName", "text", "timestamp"]
    },
    "User": {
      "title": "User Profile",
      "description": "User account data.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "description": "User's email" },
        "photoURL": { "type": "string", "description": "User's avatar URL" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role" },
        "lastVoteAt": { "type": "string", "format": "date-time", "description": "Timestamp of the last vote cast" }
      },
      "required": ["displayName", "email"]
    },
    "Video": {
      "title": "Video",
      "description": "A video uploaded by a user.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Video title" },
        "url": { "type": "string", "description": "Video URL" },
        "thumbnailUrl": { "type": "string", "description": "Video thumbnail URL" },
        "likes": { "type": "integer", "description": "Total like count" },
        "createdBy": { "type": "string", "description": "UID of the user who uploaded it" },
        "authorName": { "type": "string", "description": "Display name of the author" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "url", "createdBy", "authorName", "createdAt"]
    },
    "VideoLike": {
      "title": "Video Like",
      "description": "A like on a video.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who liked" },
        "videoId": { "type": "string", "description": "ID of the video liked" }
      },
      "required": ["userId", "videoId"]
    }
  },
  "firestore": {
    "/servers": { "schema": "Server", "description": "List of Minecraft servers" },
    "/votes": { "schema": "Vote", "description": "Tracking votes to prevent spam" },
    "/chat": { "schema": "ChatMessage", "description": "Global chat messages" },
    "/users": { "schema": "User", "description": "User profiles" },
    "/videos": { "schema": "Video", "description": "List of uploaded videos" },
    "/videoLikes": { "schema": "VideoLike", "description": "Tracking video likes" }
  }
}
